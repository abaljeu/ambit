{
    "version": "0.2.0",
    "compounds": [
        {
            "name": "Full Stack",
            "configurations": ["Launch Server",
                "Launch Client (Chrome)"]
        }
    ],
    "configurations": [
    {
            "name": "Launch Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "server: Build",
            "program": "${workspaceFolder}/src/Server/bin/Debug/net10.0/Ambit.Server.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5115"
            }
        },
        {
            "name": "Launch Client (Edge)",
            "type": "msedge",
            "request": "launch",
            "preLaunchTask": "fable: Build Client",
            "url": "http://localhost:5115/ambit",
            "webRoot": "${workspaceFolder}/src/Server/wwwroot",
            "sourceMapPathOverrides": {
                "../../Client/*": "${workspaceFolder}/src/Client/*",
                "../../../Shared/*": "${workspaceFolder}/src/Shared/*"
            }
        },
        {
            "name": "Launch Client (Chrome)",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "fable: Build Client",
            "url": "http://localhost:5115/ambit",
            "webRoot": "${workspaceFolder}/src/Server/wwwroot",
            "sourceMapPathOverrides": {
                "../../Client/*": "${workspaceFolder}/src/Client/*",
                "../../../Shared/*": "${workspaceFolder}/src/Shared/*"
            }
        }
    ]
}
