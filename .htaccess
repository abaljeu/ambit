# this is for hostgator

<Limit GET POST>
order deny,allow
deny from all
allow from all
</Limit>
<Limit PUT DELETE>
order deny,allow
deny from all
</Limit>
RewriteEngine On
# Redirect doubled path (e.g. /ambit/ambit/login -> /ambit/login)
RewriteRule ^ambit/ambit(/.*)?$ /ambit$1 [R=301,L]
# Proxy /ambit and /ambit/* to backend
RewriteRule ^ambit(/.*)?$ proxy.php?path=$1 [QSA,L]

AuthName collaborative-systems.org
IndexIgnore .htaccess */.??* *~ *# */HEADER* */README* */_vti*

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php74” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
