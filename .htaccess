# this is for hostgator

<Limit GET POST>
order deny,allow
deny from all
allow from all
</Limit>
<Limit PUT DELETE>
order deny,allow
deny from all
</Limit>
RewriteEngine On
RewriteRule ^gambol(/.*)?$ https://amble-f6bfcfdygjd9b6b7.canadacentral-01.azurewebsites.net/gambol$1 [R=302,L]

AuthName collaborative-systems.org
IndexIgnore .htaccess */.??* *~ *# */HEADER* */README* */_vti*

